<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Assessment.MainPage"
             Title="Assessment">

    <Grid ColumnDefinitions="*,*" Padding="12" ColumnSpacing="12">
    
        <CollectionView Grid.Column="0" ItemsSource="{Binding RealTimeLog}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Label Text="{Binding .}" Padding="4,4" FontFamily="Monospace"/>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Start">
            <Entry x:Name="FeedbackEntry" 
                   Placeholder="Give feedback"
                   ReturnCommand="{Binding SendCommand}"
                   ReturnType="Send"/>
            <Button Text="Send" Command="{Binding SendCommand}"/>
            <Label Text="{Binding Status}" FontSize="12" TextColor="Gray"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
