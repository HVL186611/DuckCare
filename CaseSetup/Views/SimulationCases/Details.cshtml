@model DuckLib.SimulationCase

@* style and class stuff courtesy of chatgpt *@

@{
    ViewData["Title"] = "Case Details";
    bool isEditable = Model.StudentEditable == 1 ? true : Context.Session.GetString("Role") == "teacher";
}
<p>
    <a asp-action="Index" class="btn btn-secondary">Back to cases</a>
</p>

<h1>
    @Model.Title 
    @if (isEditable)
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            Edit Case
        </a>
    }

</h1>

<p class="lead">@Model.Description</p>

<div class="mb-3">
    @if (Model.IsActive == 1)
    {
        <span class="badge bg-success">Active</span>
    }
    else
    {
        <span class="badge bg-secondary">Inactive</span>
    }

    @if (isEditable)
    {
        <span class="badge bg-info">Editable</span>
    }
    else
    {
        <span class="badge bg-warning text-dark">Uneditable</span>
    }
</div>

@* simulation case info *@
<div class="d-flex flex-wrap gap-4 align-items-start">
    <div style="width: min(100%, 560px);">
        @* patient info *@
        <h2>Patient</h2>

        <table class="table table-sm">
            <tbody>
                <tr>
                    <th style="width: 160px; white-space: nowrap;">Name</th>
                    <td style="overflow-wrap: anywhere;">@Model.Patient.Name</td>
                </tr>
                <tr>
                    <th style="width: 160px; white-space: nowrap;">Age</th>
                    <td>@Model.Patient.Age</td>
                </tr>
                <tr>
                    <th style="width: 160px; white-space: nowrap;">Sex</th>
                    <td>@Model.Patient.Sex</td>
                </tr>
                <tr>
                    <th style="width: 160px; white-space: nowrap;">Weight</th>
                    <td>@Model.Patient.WeightKg</td>
                </tr>
                <tr>
                    <th style="width: 160px; white-space: nowrap;">Medical history</th>
                    <td style="overflow-wrap: anywhere;">@Model.Patient.MedicalHistory</td>
                </tr>
                <tr>
                    <th style="width: 160px; white-space: nowrap;">Admitting diagnosis</th>
                    <td style="overflow-wrap: anywhere;">@Model.Patient.AdmittingDiagnosis</td>
                </tr>
            </tbody>
        </table>
    </div>

    @* start vitals info *@
    <div style="width: min(100%, 400px);">
        <h2>Vitals</h2>

        <table class="table table-sm">
            <tbody>
                <tr>
                    <th style="width: 220px; white-space: nowrap;">Blood pressure</th>
                    <td class="text-end">@Model.StartVitals.BPSystolic / @Model.StartVitals.BPDiastolic</td>
                </tr>
                <tr>
                    <th style="width: 220px; white-space: nowrap;">Heart rate</th>
                    <td class="text-end">@Model.StartVitals.HeartRate</td>
                </tr>
                <tr>
                    <th style="width: 220px; white-space: nowrap;">Respiratory rate</th>
                    <td class="text-end">@Model.StartVitals.RespiratoryRate</td>
                </tr>
                <tr>
                    <th style="width: 220px; white-space: nowrap;">Oxygen saturation</th>
                    <td class="text-end">@Model.StartVitals.OxygenSaturation%</td>
                </tr>
                <tr>
                    <th style="width: 220px; white-space: nowrap;">Temperature</th>
                    <td class="text-end">@Model.StartVitals.Temperature</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<h2>Allergies</h2>

@if (Model.Allergies == null || !Model.Allergies.Any())
{
    <p class="text-muted">No allergies registered.</p>
}
else
{
    <table class="table table-sm table-striped" style="max-width: 800px;">
        <thead>
            <tr>
                <th>Allergen</th>
                <th>Reaction</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var allergy in Model.Allergies)
            {
                <tr>
                    <td>@allergy.Allergen</td>
                    <td>@allergy.Reaction</td>
                </tr>
            }
        </tbody>
    </table>
}
<h2>Current Medications</h2>

@if (Model.Patient.Medications == null || !Model.Patient.Medications.Any())
{
    <p class="text-muted">No current medications registered.</p>
}
else
{
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Medication</th>
                <th>Dose</th>
                <th>Unit</th>
                <th>Route</th>
                <th>Timing</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var medicationOrder in Model.Patient.Medications)
            {
                <tr>
                    <td>@medicationOrder.Medication.Name</td>
                    <td>@medicationOrder.Dose</td>
                    <td>@medicationOrder.DoseUnit</td>
                    <td>@medicationOrder.Route</td>
                    <td>@medicationOrder.Timing</td>
                </tr>
            }
        </tbody>
    </table>
}
<h2>Lab Values</h2>

@if (Model.LabValues == null || !Model.LabValues.Any())
{
    <p class="text-muted">No lab values registered.</p>
}
else
{
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Value</th>
                <th>Reference</th>
                <th>Interpretation</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var labValue in Model.LabValues)
            {
                <tr>
                    <td>@labValue.Name</td>
                    <td>@labValue.Value</td>
                    <td>@labValue.Reference</td>
                    <td>@labValue.Interpretation</td>
                </tr>
            }
        </tbody>
    </table>
}

<h2>Goals</h2>
<div>@Model.Goals.Description</div>
