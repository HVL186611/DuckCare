@model DuckLib.SimulationCase

@{
    bool isEdit = Model.Id != 0;
    var medications = ViewBag.Medications as List<string> ?? new List<string> { "Could not fetch medications." };
    ViewData["Title"] = isEdit ? "Edit Simulation Case" : "Create Simulation Case";
}

<h1>@(isEdit ? "Edit \"" + Model.Title + '"' : "Create Simulation Case")</h1>

<p class="text-muted">
    Fill in the details for the scenario, patient, starting vitals, and simulation goals.
</p>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <!-- hidden Id field so create page can be reused for updates as well -->
    <input type="hidden" asp-for="Id" />

    <div class="card mb-4">
        <div class="card-body">

            <fieldset class="border rounded p-3 mb-4">
                <legend class="float-none w-auto px-2 fs-5 fw-bold">Case Information</legend>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-bold"></label>
                    <input asp-for="Title" class="form-control" placeholder="Example: Acute hypoquackemia" />
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"
                              placeholder="A duck ate moldy bread, this is what happened to his organs..."></textarea>
                </div>
            </fieldset>

            <!-- specify who will be abused in the sim -->
            <fieldset class="border rounded p-3 mb-4">
                <legend class="float-none w-auto px-2 fs-5 fw-bold">Patient</legend>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="Patient.Name" class="form-label fw-bold">Name</label>
                        <input asp-for="Patient.Name" class="form-control" placeholder="Patient name" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Patient.Age" class="form-label fw-bold">Age</label>
                        <input asp-for="Patient.Age" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Patient.Sex" class="form-label fw-bold">Sex</label>
                        <select asp-for="Patient.Sex" class="form-select">
                            <option value="">Select</option>
                            <option>Female</option>
                            <option>Male</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Patient.WeightKg" class="form-label fw-bold">Weight (kg)</label>
                        <input asp-for="Patient.WeightKg" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Patient.HeightCm" class="form-label fw-bold">Height (cm)</label>
                        <input asp-for="Patient.HeightCm" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Patient.AdmissionDate" class="form-label fw-bold">Admission Date</label>
                        <input asp-for="Patient.AdmissionDate" class="form-control" type="datetime-local" />
                    </div>

                    <div class="col-12">
                        <label asp-for="Patient.AdmittingDiagnosis" class="form-label fw-bold">Admitting Diagnosis</label>
                        <input asp-for="Patient.AdmittingDiagnosis" class="form-control" />
                    </div>

                    <div class="col-12">
                        <label asp-for="Patient.MedicalHistory" class="form-label fw-bold">Medical History</label>
                        <textarea asp-for="Patient.MedicalHistory" class="form-control" rows="4"></textarea>
                    </div>
                </div>
            </fieldset>

            <!-- specify how ducked said person is -->
            <fieldset class="border rounded p-3 mb-4">
                <legend class="float-none w-auto px-2 fs-5 fw-bold">Starting Vitals</legend>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="StartVitals.BPSystolic" class="form-label fw-bold">BP Systolic</label>
                        <input asp-for="StartVitals.BPSystolic" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="StartVitals.BPDiastolic" class="form-label fw-bold">BP Diastolic</label>
                        <input asp-for="StartVitals.BPDiastolic" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="StartVitals.HeartRate" class="form-label fw-bold">Heart Rate</label>
                        <input asp-for="StartVitals.HeartRate" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="StartVitals.RespiratoryRate" class="form-label fw-bold">Respiratory Rate</label>
                        <input asp-for="StartVitals.RespiratoryRate" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="StartVitals.OxygenSaturation" class="form-label fw-bold">Oxygen Saturation (%)</label>
                        <input asp-for="StartVitals.OxygenSaturation" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="StartVitals.Temperature" class="form-label fw-bold">Temperature (°C)</label>
                        <input asp-for="StartVitals.Temperature" class="form-control" />
                    </div>
                </div>
            </fieldset>

            <!-- if ducking up their vitals isn't enough, feel free to duck with their allergies too -->
            <fieldset class="border rounded p-3 mb-4">
                <legend class="float-none w-auto px-2 fs-5 fw-bold">Allergies</legend>

                <div id="allergies-list">
                    @for (int i = 0; i < Model.Patient.Allergies.Count; i++)
                    {
                        <div class="border rounded p-3 mb-3 allergy-row">
                            <div class="row g-3 align-items-end">
                                <div class="col-md-5">
                                    <label class="form-label fw-bold">Allergen</label>
                                    <input name="Patient.Allergies[@i].Allergen"
                                           value="@Model.Patient.Allergies[i].Allergen"
                                           class="form-control"
                                           placeholder="Example: Potatoes" />
                                </div>

                                <div class="col-md-5">
                                    <label class="form-label fw-bold">Reaction</label>
                                    <input name="Patient.Allergies[@i].Reaction"
                                           value="@Model.Patient.Allergies[i].Reaction"
                                           class="form-control"
                                           placeholder="Tummy ache :<" />
                                </div>

                                <div class="col-md-2">
                                    <button type="button" class="btn btn-outline-danger w-100" onclick="removeRow(this)">
                                        Remove
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <button type="button" class="btn btn-secondary" onclick="addAllergy()">
                    Add allergy
                </button>
            </fieldset>
            
            <!-- specify how many drugs the patient takes to cope with how much you ducked up their life -->
            <fieldset class="border rounded p-3 mb-4">
                <legend class="float-none w-auto px-2 fs-5 fw-bold">Current Medications</legend>

                <div id="medications-list">
                    @for (int i = 0; i < Model.Patient.Medications.Count; i++)
                    {
                        <div class="border rounded p-3 mb-3 medication-row">
                            <div class="row g-3 align-items-end">
                                <div class="col-md-3">
                                    <label class="form-label fw-bold">Medication</label>
                                    <select name="Patient.Medications[@i].Medication.Name" class="form-select">
                                        <option value="">Select medication</option>

                                        @foreach (string medicationName in medications)
                                        {
                                            if (Model.Patient.Medications[i].Medication.Name == medicationName)
                                            {
                                                <option value="@medicationName" selected>@medicationName</option>
                                            }
                                            else
                                            {
                                                <option value="@medicationName">@medicationName</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label fw-bold">Dose</label>
                                    <input name="Patient.Medications[@i].Dose"
                                           value="@Model.Patient.Medications[i].Dose"
                                           class="form-control"
                                           placeholder="5 slices" />
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label fw-bold">Route</label>
                                    <input name="Patient.Medications[@i].Route"
                                           value="@Model.Patient.Medications[i].Route"
                                           class="form-control"
                                           placeholder="Mouth" />
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label fw-bold">Frequency</label>
                                    <input name="Patient.Medications[@i].Timing"
                                           value="@Model.Patient.Medications[i].Timing"
                                           class="form-control"
                                           placeholder="Once daily" />
                                </div>

                                <div class="col-md-2">
                                    <button type="button" class="btn btn-outline-danger w-100" onclick="removeRow(this)">
                                        Remove
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <button type="button" class="btn btn-secondary" onclick="addMedication()">
                    Add medication
                </button>
            </fieldset>

            <!-- send some urine and blood to the local witch and they'll brew up some lab values for you -->
            <fieldset class="border rounded p-3 mb-4">
                <legend class="float-none w-auto px-2 fs-5 fw-bold">Lab Values</legend>

                <div id="labvalues-list">
                    @for (int i = 0; i < Model.LabValues.Count; i++)
                    {
                        <div class="border rounded p-3 mb-3 labvalue-row">
                            <div class="row g-3 align-items-end">
                                <div class="col-md-3">
                                    <label class="form-label fw-bold">Name</label>
                                    <input name="LabValues[@i].Name"
                                           value="@Model.LabValues[i].Name"
                                           class="form-control"
                                           placeholder="Feathers" />
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label fw-bold">Value</label>
                                    <input name="LabValues[@i].Value"
                                           value="@Model.LabValues[i].Value"
                                           class="form-control"
                                           placeholder="Very shiny" />
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label fw-bold">Reference</label>
                                    <input name="LabValues[@i].Reference"
                                           value="@Model.LabValues[i].Reference"
                                           class="form-control"
                                           placeholder="Shiny" />
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label fw-bold">Interpretation</label>
                                    <input name="LabValues[@i].Interpretation"
                                           value="@Model.LabValues[i].Interpretation"
                                           class="form-control"
                                           placeholder="duck=pretty" />
                                </div>

                                <div class="col-md-2">
                                    <button type="button" class="btn btn-outline-danger w-100" onclick="removeRow(this)">
                                        Remove
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <button type="button" class="btn btn-secondary" onclick="addLabValue()">
                    Add lab value
                </button>
            </fieldset>

            <!-- specify goals, because our future doctors aren't expected to figure that out themselves -->
            <fieldset class="border rounded p-3 mb-4">
                <legend class="float-none w-auto px-2 fs-5 fw-bold">Simulation Goals</legend>

                <div class="mb-3">
                    <label asp-for="Goals.Description" class="form-label fw-bold">Description</label>
                    <textarea asp-for="Goals.Description" class="form-control" rows="4"
                              placeholder="What should the student achieve?"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Goals.TimerMinutes" class="form-label fw-bold">Goal Time (minutes)</label>
                    <input asp-for="Goals.TimerMinutes" class="form-control" style="max-width: 250px;" />
                </div>

                <p class="text-muted mb-3">
                    Target ranges for a stable adult patient. Leave empty if a value is not relevant for this case.
                </p>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Systolic Blood Pressure</label>
                        <div class="input-group">
                            <input name="Goals.SystolicBP.Min"
                                   value="@(Model.Goals.SystolicBP?.Min)"
                                   class="form-control"
                                   placeholder="90" />
                            <span class="input-group-text">to</span>
                            <input name="Goals.SystolicBP.Max"
                                   value="@(Model.Goals.SystolicBP?.Max)"
                                   class="form-control"
                                   placeholder="120" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Diastolic Blood Pressure</label>
                        <div class="input-group">
                            <input name="Goals.DiastolicBP.Min"
                                   value="@(Model.Goals.DiastolicBP?.Min)"
                                   class="form-control"
                                   placeholder="80" />
                            <span class="input-group-text">to</span>
                            <input name="Goals.DiastolicBP.Max"
                                   value="@(Model.Goals.DiastolicBP?.Max)"
                                   class="form-control"
                                   placeholder="90" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Heart Rate</label>
                        <div class="input-group">
                            <input name="Goals.HeartRate.Min"
                                   value="@(Model.Goals.HeartRate?.Min)"
                                   class="form-control"
                                   placeholder="60" />
                            <span class="input-group-text">to</span>
                            <input name="Goals.HeartRate.Max"
                                   value="@(Model.Goals.HeartRate?.Max)"
                                   class="form-control"
                                   placeholder="100" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Respiratory Rate</label>
                        <div class="input-group">
                            <input name="Goals.RespiratoryRate.Min"
                                   value="@(Model.Goals.RespiratoryRate?.Min)"
                                   class="form-control"
                                   placeholder="12" />
                            <span class="input-group-text">to</span>
                            <input name="Goals.RespiratoryRate.Max"
                                   value="@(Model.Goals.RespiratoryRate?.Max)"
                                   class="form-control"
                                   placeholder="20" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">SpO2 (%)</label>
                        <div class="input-group">
                            <input name="Goals.SpO2.Min"
                                   value="@(Model.Goals.SpO2?.Min)"
                                   class="form-control"
                                   placeholder="95" />
                            <span class="input-group-text">to</span>
                            <input name="Goals.SpO2.Max"
                                   value="@(Model.Goals.SpO2?.Max)"
                                   class="form-control"
                                   placeholder="100" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Temperature (°C)</label>
                        <div class="input-group">
                            <input name="Goals.Temperature.Min"
                                   value="@(Model.Goals.Temperature?.Min)"
                                   class="form-control"
                                   placeholder="36.1" />
                            <span class="input-group-text">to</span>
                            <input name="Goals.Temperature.Max"
                                   value="@(Model.Goals.Temperature?.Max)"
                                   class="form-control"
                                   placeholder="37.2" />
                        </div>
                    </div>
                </div>
            </fieldset>

            <!-- how to repair [insert patient] 101 -->
            <fieldset class="border rounded p-3 mb-4">
                <legend class="float-none w-auto px-2 fs-5 fw-bold">
                    Simulation Orders / Correct Interventions
                </legend>

                <p class="text-muted">
                    These are the clinically correct medication orders students are expected to perform during the simulation.
                    They will be used later to compare against student actions during debrief.
                </p>

                <div id="orders-list">
                    @for (int i = 0; i < Model.Orders.Count; i++)
                    {
                        <div class="border rounded p-3 mb-3 order-row">
                            <div class="row g-3 align-items-end">
                                <div class="col-md-3">
                                    <label class="form-label fw-bold">Medication</label>
                                    <select name="Orders[@i].Medication.Name" class="form-select">
                                        <option value="">Select medication</option>

                                        @foreach (string medicationName in medications)
                                        {
                                            if (Model.Orders[i].Medication.Name == medicationName)
                                            {
                                                <option value="@medicationName" selected>@medicationName</option>
                                            }
                                            else
                                            {
                                                <option value="@medicationName">@medicationName</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label fw-bold">Dose</label>
                                    <input name="Orders[@i].Dose"
                                           value="@Model.Orders[i].Dose"
                                           class="form-control"
                                           placeholder="20" />
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label fw-bold">Dose Unit</label>
                                    <select name="Orders[@i].DoseUnit" class="form-select">
                                        @foreach (string doseUnit in new List<string> { "mg", "g", "mcg", "mL", "L", "IE", "mmol" })
                                        {
                                            if (Model.Orders[i].DoseUnit == doseUnit)
                                            {
                                                <option value="@doseUnit" selected>@doseUnit</option>
                                            }
                                            else
                                            {
                                                <option value="@doseUnit">@doseUnit</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label fw-bold">Route</label>
                                    <input name="Orders[@i].Route"
                                           value="@Model.Orders[i].Route"
                                           class="form-control"
                                           placeholder="Example: IV" />
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label fw-bold">Timing</label>
                                    <input name="Orders[@i].Timing"
                                           value="@Model.Orders[i].Timing"
                                           class="form-control"
                                           placeholder="STAT / PRN" />
                                </div>

                                <div class="col-md-1">
                                    <button type="button" class="btn btn-outline-danger w-100" onclick="removeRow(this)">
                                        Remove
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <button type="button" class="btn btn-secondary" onclick="addOrder()">
                    Add order
                </button>
            </fieldset>

            <!-- -->
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">@(isEdit ? "Save changes" : "Create case")</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>

        </div>
    </div>
</form>


<!-- script -->
@section Scripts {
    <script>
        const medications = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(medications));
        const doseUnits = ["mg", "g", "mcg", "mL", "L", "IE", "mmol"];

        let allergyIndex = @Model.Patient.Allergies.Count;
        let medicationIndex = @Model.Patient.Medications.Count;
        let labValueIndex = @Model.LabValues.Count;
        let orderIndex = @Model.Orders.Count;

        function removeRow(button) {
            const row = button.closest(".border.rounded");
            row.remove();
        }

        function medicationSelectHtml(name) {
            let html = `<select name="${name}" class="form-select">`;
            html += `<option value="">Select medication</option>`;

            medications.forEach(function (medicationName) {
                html += `<option value="${escapeHtml(medicationName)}">${escapeHtml(medicationName)}</option>`;
            });

            html += `</select>`;
            return html;
        }

        function doseUnitSelectHtml(name) {
            let html = `<select name="${name}" class="form-select">`;

            doseUnits.forEach(function (doseUnit) {
                html += `<option value="${escapeHtml(doseUnit)}">${escapeHtml(doseUnit)}</option>`;
            });

            html += `</select>`;
            return html;
        }

        function escapeHtml(value) {
            return String(value)
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function addOrder() {
            const list = document.getElementById("orders-list");

            const html = `
                <div class="border rounded p-3 mb-3 order-row">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Medication</label>
                            ${medicationSelectHtml(`Orders[${orderIndex}].Medication.Name`)}
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-bold">Dose</label>
                            <input name="Orders[${orderIndex}].Dose"
                                   class="form-control"
                                   placeholder="20" />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-bold">Dose Unit</label>
                            ${doseUnitSelectHtml(`Orders[${orderIndex}].DoseUnit`)}
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-bold">Route</label>
                            <input name="Orders[${orderIndex}].Route"
                                   class="form-control"
                                   placeholder="Example: IV" />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-bold">Timing</label>
                            <input name="Orders[${orderIndex}].Timing"
                                   class="form-control"
                                   placeholder="STAT / PRN" />
                        </div>

                        <div class="col-md-1">
                            <button type="button"
                                    class="btn btn-outline-danger w-100"
                                    onclick="removeRow(this)">
                                Remove
                            </button>
                        </div>
                    </div>
                </div>
            `;

            list.insertAdjacentHTML("beforeend", html);
            orderIndex++;
        }

        function addAllergy() {
            const list = document.getElementById("allergies-list");

            const html = `
                <div class="border rounded p-3 mb-3 allergy-row">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-5">
                            <label class="form-label fw-bold">Allergen</label>
                            <input name="Patient.Allergies[${allergyIndex}].Allergen" class="form-control" placeholder="Example: Penicillin" />
                        </div>

                        <div class="col-md-5">
                            <label class="form-label fw-bold">Reaction</label>
                            <input name="Patient.Allergies[${allergyIndex}].Reaction" class="form-control" placeholder="Example: Rash" />
                        </div>

                        <div class="col-md-2">
                            <button type="button" class="btn btn-outline-danger w-100" onclick="removeRow(this)">
                                Remove
                            </button>
                        </div>
                    </div>
                </div>
            `;

            list.insertAdjacentHTML("beforeend", html);
            allergyIndex++;
        }

        function addMedication() {
            const list = document.getElementById("medications-list");

            const html = `
                <div class="border rounded p-3 mb-3 medication-row">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Medication</label>
                            ${medicationSelectHtml(`Patient.Medications[${medicationIndex}].Medication.Name`)}
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-bold">Dose</label>
                            <input name="Patient.Medications[${medicationIndex}].Dose" class="form-control" placeholder="5 mg" />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-bold">Route</label>
                            <input name="Patient.Medications[${medicationIndex}].Route" class="form-control" placeholder="PO / IV" />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-bold">Frequency</label>
                            <input name="Patient.Medications[${medicationIndex}].Timing" class="form-control" placeholder="Once daily" />
                        </div>

                        <div class="col-md-2">
                            <button type="button" class="btn btn-outline-danger w-100" onclick="removeRow(this)">
                                Remove
                            </button>
                        </div>
                    </div>
                </div>
            `;

            list.insertAdjacentHTML("beforeend", html);
            medicationIndex++;
        }

        function addLabValue() {
            const list = document.getElementById("labvalues-list");

            const html = `
                <div class="border rounded p-3 mb-3 labvalue-row">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Name</label>
                            <input name="LabValues[${labValueIndex}].Name" class="form-control" placeholder="Example: CRP" />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-bold">Value</label>
                            <input name="LabValues[${labValueIndex}].Value" class="form-control" placeholder="120" />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-bold">Reference</label>
                            <input name="LabValues[${labValueIndex}].Reference" class="form-control" placeholder="< 5" />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-bold">Interpretation</label>
                            <input name="LabValues[${labValueIndex}].Interpretation" class="form-control" placeholder="High" />
                        </div>

                        <div class="col-md-2">
                            <button type="button" class="btn btn-outline-danger w-100" onclick="removeRow(this)">
                                Remove
                            </button>
                        </div>
                    </div>
                </div>
            `;

            list.insertAdjacentHTML("beforeend", html);
            labValueIndex++;
        }
    </script>
}