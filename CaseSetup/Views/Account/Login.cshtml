@{
    ViewData["Title"] = "Login";
}

<h1>Login</h1>

<p class="text-muted">
    Choose your role. The magic words are only required for teacher login.
</p>

<form asp-action="Login" method="post" style="max-width: 420px;">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label for="role" class="form-label fw-bold">Role</label>
        <select name="role" id="role" class="form-select">
            <option value="">Select role</option>
            <option value="Teacher">Teacher</option>
            <option value="Student">Student</option>
        </select>
    </div>
    <div class="mb-3">
        <label for="password" class="form-label fw-bold">What are the magic words?</label>
        <input name="password" id="password" type="password" class="form-control"
               placeholder="Only required for teacher login" />
        <i class="text-muted">psst! the magic words are "i love ducks"</i>
    </div>
    

    <button type="submit" class="btn btn-primary">Continue</button>
</form>
